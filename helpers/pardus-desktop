#!/usr/bin/env bash

DESKTOP_FILE_TUI="/usr/share/applications/pardus.desktop"
DESKTOP_FILE_GUI="/usr/share/applications/pardus-gui.desktop"

echo Creating the desktop shortcut - Masaüstü kısayolu oluşturuluyor
sudo touch "$DESKTOP_FILE_TUI" "$DESKTOP_FILE_GUI"

sudo tee "$DESKTOP_FILE_TUI" > /dev/null <<EOF
[Desktop Entry]
Name=Pardus Package Manager (TUI)
Name[tr]=Pardus Paket Yöneticisi
Comment=Interactive package manager for Pardus
Comment[tr]=Pardus için etkileşimli paket yöneticisi
Exec=pkexec /usr/bin/pardus
Icon=system-software-install
Terminal=true
Type=Application
Categories=System;
EOF

sudo tee "$DESKTOP_FILE_GUI" > /dev/null <<EOF
[Desktop Entry]
Name=Pardus Package Manager (GUI)
Name[tr]=Pardus Paket Yöneticisi (GUI)
Comment=Interactive package manager for Pardus
Comment[tr]=Pardus için etkileşimli paket yöneticisi
Exec=python3 /usr/bin/pardus-gui
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;
EOF

sudo chmod 644 "$DESKTOP_FILE_TUI"
sudo chmod 644 "$DESKTOP_FILE_GUI"

DESKTOP_DIR=$(xdg-user-dir DESKTOP 2>/dev/null)

if [ -n "$DESKTOP_DIR" ]; then
    cp "$DESKTOP_FILE_TUI" "$DESKTOP_DIR/pardus.desktop"
    cp "$DESKTOP_FILE_GUI" "$DESKTOP_DIR/pardus-gui.desktop"
    chmod 755 "$DESKTOP_DIR/pardus.desktop"
    chmod 755 "$DESKTOP_DIR/pardus-gui.desktop"
fi

echo Desktop shortcut created successfully - Masaüstü kısayolu başarıyla oluşturuldu
