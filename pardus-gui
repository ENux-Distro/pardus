        lay.setContentsMargins(28, 28, 28, 28)
        lay.setSpacing(16)
        c = self._card()
        cl = QVBoxLayout(c)
        cl.setContentsMargins(20, 20, 20, 20)
        cl.setSpacing(12)
        self.cmd_lbl = QLabel("$  apt remove --autoremove --purge -y  <package>")
        self.cmd_lbl.setStyleSheet(
            "color:#ff5555;font-family:monospace;font-size:11px;"
            "background:#1a0000;border:1px solid #3a0000;"
            "border-radius:5px;padding:6px 12px;"
        )
        row = QHBoxLayout()
        row.setSpacing(10)
        self.inp = QLineEdit()
        self.inp.setPlaceholderText(t("remove_placeholder"))
        self.inp.setMinimumHeight(40)
        self.rbtn = QPushButton(t("remove_btn"))
        self.rbtn.setObjectName("danger")
        self.rbtn.setMinimumHeight(40)
        row.addWidget(self.inp)
        row.addWidget(self.rbtn)
        self.pbar = QProgressBar()
        self.pbar.setFixedHeight(5)
        self.pbar.setValue(0)
        cl.addWidget(self.cmd_lbl)
        cl.addLayout(row)
        cl.addWidget(self.pbar)
        lay.addWidget(c)
        lay.addStretch()
        self.rbtn.clicked.connect(self._remove)
        self.inp.returnPressed.connect(self._remove)

    def _remove(self):
        pkg = self.inp.text().strip()
        if not pkg:
            self.log.emit(f"[!] {self.t('pkg_required')}\n")
            return
        dlg = QDialog(self)
        dlg.setWindowTitle(self.t("confirm_remove"))
        dlg.setStyleSheet("QDialog{background:#181818;}QLabel{color:#f0f0f0;}")
        dlg.setMinimumWidth(320)
        vl = QVBoxLayout(dlg)
        vl.setSpacing(16)
        vl.setContentsMargins(22, 22, 22, 16)
        lbl = QLabel(f"{self.t('confirm_remove')}\n{pkg}")
        lbl.setStyleSheet("color:#f0f0f0;font-size:14px;")
        vl.addWidget(lbl)
        btns = QHBoxLayout()
        btns.setSpacing(10)
        yes = QPushButton(self.t("confirm_yes"))
        yes.setObjectName("danger")
        no  = QPushButton(self.t("confirm_no"))
        no.setObjectName("ghost")
        btns.addStretch()
        btns.addWidget(no)
        btns.addWidget(yes)
        vl.addLayout(btns)
        yes.clicked.connect(dlg.accept)
        no.clicked.connect(dlg.reject)
        if dlg.exec() != QDialog.DialogCode.Accepted:
            return
        self.log.emit(f"\n[->] apt remove --autoremove --purge -y {pkg}\n")
        self._run(["remove", "--autoremove", "--purge", "-y", pkg],
                  pbar=self.pbar, btn=self.rbtn)

    def retranslate(self):
        self.inp.setPlaceholderText(self.t("remove_placeholder"))
        self.rbtn.setText(self.t("remove_btn"))


