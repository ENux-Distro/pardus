        self.clr.setText(self.t("console_clear"))
        self.cpy.setText(self.t("console_copy"))


NAV_KEYS = [
    ("nav_search",  "Search"),
    ("nav_install", "Install"),
    ("nav_remove",  "Remove"),
    ("nav_update",  "Update"),
    ("nav_upgrade", "Upgrade"),
    ("nav_console", "Console"),
]

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self._lang = "TR"
        self.setWindowTitle(self.t("app_title"))
        self.setMinimumSize(960, 600)
        self.resize(1080, 680)
        self.setStyleSheet(QSS)
        self._build()
        self._wire()
        self._console.insertPlainText(
            "===========================================\n"
	    "                                    Pardus   Package   Manager\n"
            "===========================================\n"
            "Hazır / Ready.\n\n"
        )

    def t(self, key):
        return TR[self._lang].get(key, key)

    def _build(self):
        root_w = QWidget()
        self.setCentralWidget(root_w)
        root = QHBoxLayout(root_w)
        root.setContentsMargins(0, 0, 0, 0)
        root.setSpacing(0)

        # SIDEBAR
        sb_w = QWidget()
        sb_w.setObjectName("sidebar")
        sb_w.setFixedWidth(188)
        sb = QVBoxLayout(sb_w)
        sb.setContentsMargins(0, 0, 0, 0)
        sb.setSpacing(0)

        logo_block = QWidget()
        logo_block.setObjectName("logo_block")
        logo_block.setFixedHeight(76)
        lb = QHBoxLayout(logo_block)
        lb.setContentsMargins(16, 0, 16, 0)
        lb.setSpacing(12)
        icon_lbl = QLabel()
        icon_lbl.setPixmap(make_logo(34))
        icon_lbl.setFixedSize(34, 34)
        tc = QVBoxLayout()
        tc.setSpacing(1)
        n = QLabel("Pardus")
        n.setObjectName("logo_name")
        s = QLabel("PKG MGR")
        s.setObjectName("logo_sub")
        tc.addWidget(n)
        tc.addWidget(s)
        lb.addWidget(icon_lbl)
        lb.addLayout(tc)
        sb.addWidget(logo_block)

        self._nav_btns: dict[str, QPushButton] = {}
        for key, _ in NAV_KEYS:
            btn = QPushButton(self.t(key))
            btn.setObjectName("nav")
            btn.setProperty("active", False)
            btn.setMinimumHeight(44)
            self._nav_btns[key] = btn
            sb.addWidget(btn)

        sb.addStretch()

        self._lang_btn = QPushButton(self.t("lang_toggle"))
        self._lang_btn.setObjectName("ghost")
        self._lang_btn.setFixedHeight(32)
        lw = QWidget()
        lwl = QVBoxLayout(lw)
        lwl.setContentsMargins(14, 8, 14, 12)
        lwl.addWidget(self._lang_btn)
        sb.addWidget(lw)

        root.addWidget(sb_w)

        # RIGHT
        rw = QWidget()
        rw.setObjectName("content")
        rl = QVBoxLayout(rw)
        rl.setContentsMargins(0, 0, 0, 0)
        rl.setSpacing(0)

        hdr = QWidget()
        hdr.setObjectName("page_header")
        hdr.setFixedHeight(64)
        hdrl = QVBoxLayout(hdr)
        hdrl.setContentsMargins(28, 10, 28, 10)
        hdrl.setSpacing(2)
        self._page_title = QLabel()
        self._page_title.setObjectName("page_title")
        self._page_sub = QLabel()
        self._page_sub.setObjectName("page_sub")
        hdrl.addWidget(self._page_title)
        hdrl.addWidget(self._page_sub)
        rl.addWidget(hdr)

        self._console = QTextEdit()
        self._console.setObjectName("console")
        self._console.setReadOnly(True)
        self._console.setLineWrapMode(QTextEdit.LineWrapMode.NoWrap)

        self._stack = QStackedWidget()
        self._pages: dict[str, QWidget] = {
            "nav_search":  SearchPage(self.t),
            "nav_install": InstallPage(self.t),
            "nav_remove":  RemovePage(self.t),
            "nav_update":  UpdatePage(self.t),
            "nav_upgrade": UpgradePage(self.t),
            "nav_console": ConsolePage(self.t, self._console),
        }
        for pg in self._pages.values():
            self._stack.addWidget(pg)
        rl.addWidget(self._stack)

        stat = QWidget()
        stat.setObjectName("statusbar")
        stat.setFixedHeight(26)
        stl = QHBoxLayout(stat)
        stl.setContentsMargins(20, 0, 20, 0)
        self._status = QLabel(self.t("status_ready"))
        self._status.setStyleSheet("color:#f5c400;font-size:11px;font-weight:600;")
        ver = QLabel("")
        ver.setStyleSheet("color:#444444;font-size:10px;")
        stl.addWidget(self._status)
        stl.addStretch()
        stl.addWidget(ver)
        rl.addWidget(stat)

        root.addWidget(rw)

        for key, btn in self._nav_btns.items():
            btn.clicked.connect(lambda _, k=key: self._goto(k))
        self._lang_btn.clicked.connect(self._flip)
        self._goto("nav_search")

    def _wire(self):
        for pg in self._pages.values():
            if isinstance(pg, Page):
                pg.log.connect(self._log)
                pg.done.connect(self._on_done)

    def _goto(self, key):
        for k, btn in self._nav_btns.items():
            active = (k == key)
            btn.setProperty("active", active)
            btn.style().unpolish(btn)
            btn.style().polish(btn)
        self._stack.setCurrentWidget(self._pages[key])
        self._page_title.setText(self.t(key))
        self._page_sub.setText("")

    def _log(self, text):
        cur = self._console.textCursor()
        cur.movePosition(QTextCursor.MoveOperation.End)
        self._console.setTextCursor(cur)
        self._console.insertPlainText(text)
        self._console.ensureCursorVisible()
        self._status.setText(self.t("status_running"))
        self._status.setStyleSheet("color:#f5c400;font-size:11px;font-weight:600;")

    def _on_done(self, ok):
        col = "#3ddc84" if ok else "#ff5555"
        self._status.setText(self.t("status_done" if ok else "status_error"))
        self._status.setStyleSheet(f"color:{col};font-size:11px;font-weight:600;")
        Toast(self, self.t("toast_ok" if ok else "toast_err"), ok=ok)
        QTimer.singleShot(4000, lambda: (
            self._status.setText(self.t("status_ready")),
            self._status.setStyleSheet(
                "color:#f5c400;font-size:11px;font-weight:600;"
            ),
        ))

    def _flip(self):
        self._lang = "EN" if self._lang == "TR" else "TR"
        self.setWindowTitle(self.t("app_title"))
        self._lang_btn.setText(self.t("lang_toggle"))
        for key, btn in self._nav_btns.items():
            btn.setText(self.t(key))
        for pg in self._pages.values():
            if hasattr(pg, "retranslate"):
                pg.retranslate()
        cur = [k for k, p in self._pages.items() if p is self._stack.currentWidget()]
        if cur:
            self._page_title.setText(self.t(cur[0]))


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Pardus Pkg Mgr")
    w = MainWindow()
    w.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
