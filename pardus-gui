        self.title.setStyleSheet("font-size:16px;font-weight:700;color:#f0f0f0;")
        self.desc = QLabel(t("upgrade_desc"))
        self.desc.setStyleSheet("color:#888888;font-size:12px;")
        self.desc.setWordWrap(True)
        cmd = QLabel("$  apt upgrade -y")
        cmd.setStyleSheet(
            "color:#f5c400;font-family:monospace;font-size:11px;"
            "background:#0f0f00;border:1px solid #2a2a00;"
            "border-radius:5px;padding:6px 12px;"
        )
        self.run_btn = QPushButton(t("upgrade_btn"))
        self.run_btn.setObjectName("primary")
        self.run_btn.setMinimumHeight(42)
        self.run_btn.setFixedWidth(220)
        self.pbar = QProgressBar()
        self.pbar.setFixedHeight(6)
        self.pbar.setValue(0)
        cl.addWidget(self.title)
        cl.addWidget(self.desc)
        cl.addWidget(cmd)
        cl.addSpacing(4)
        cl.addWidget(self.run_btn, alignment=Qt.AlignmentFlag.AlignLeft)
        cl.addWidget(self.pbar)
        lay.addWidget(c)
        lay.addStretch()
        self.run_btn.clicked.connect(self._upgrade)

    def _upgrade(self):
        self.log.emit("\n[->] apt upgrade -y\n")
        self._run(["upgrade", "-y"], pbar=self.pbar, btn=self.run_btn)

    def retranslate(self):
        self.title.setText(self.t("upgrade_title"))
        self.desc.setText(self.t("upgrade_desc"))
        self.run_btn.setText(self.t("upgrade_btn"))


class ConsolePage(QWidget):
    def __init__(self, t, console):
        super().__init__()
        self.t = t
        self.con = console
        lay = QVBoxLayout(self)
        lay.setContentsMargins(28, 28, 28, 28)
        lay.setSpacing(10)
        top = QHBoxLayout()
        self.ttl = QLabel(t("console_title"))
        self.ttl.setStyleSheet("font-size:15px;font-weight:700;color:#f0f0f0;")
        self.clr = QPushButton(t("console_clear"))
        self.clr.setObjectName("ghost")
        self.cpy = QPushButton(t("console_copy"))
        self.cpy.setObjectName("ghost")
        top.addWidget(self.ttl)
        top.addStretch()
        top.addWidget(self.cpy)
        top.addWidget(self.clr)
        lay.addLayout(top)
        lay.addWidget(self.con)
