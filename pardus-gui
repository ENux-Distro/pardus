def make_logo(size=36):
    px = QPixmap(size, size)
    px.fill(Qt.GlobalColor.transparent)
    p = QPainter(px)
    p.setRenderHint(QPainter.RenderHint.Antialiasing)
    p.setBrush(QBrush(QColor("#f5c400")))
    p.setPen(Qt.PenStyle.NoPen)
    p.drawEllipse(0, 0, size, size)
    p.setPen(QPen(QColor("#0a0a0a")))
    font = QFont("sans-serif", int(size * 0.42), QFont.Weight.Black)
    p.setFont(font)
    p.drawText(px.rect(), Qt.AlignmentFlag.AlignCenter, "P")
    p.end()
    return px


class Toast(QFrame):
    def __init__(self, parent, msg, ok=True):
        super().__init__(parent)
        self.setFixedSize(360, 48)
        bg  = "#0d2a1a" if ok else "#2a0a0a"
        bdr = "#1a5a30" if ok else "#5a1a1a"
        col = "#3ddc84" if ok else "#ff5555"
        ico = "checkmark" if ok else "x"
        self.setStyleSheet(
            f"background:{bg};border:1px solid {bdr};border-radius:9px;"
        )
        lay = QHBoxLayout(self)
        lay.setContentsMargins(14, 0, 14, 0)
        lay.setSpacing(10)
        i = QLabel("OK" if ok else "ERR")
        i.setStyleSheet(f"color:{col};font-size:11px;font-weight:bold;")
        m = QLabel(msg)
        m.setStyleSheet(f"color:{col};font-size:12px;font-weight:600;")
        lay.addWidget(i)
        lay.addWidget(m)
        lay.addStretch()
        sh = QGraphicsDropShadowEffect()
        sh.setBlurRadius(24)
        sh.setColor(QColor(0, 0, 0, 160))
        sh.setOffset(0, 6)
        self.setGraphicsEffect(sh)
        self.move(parent.width() - self.width() - 20,
                  parent.height() - self.height() - 56)
        self.raise_()
        self.show()
        QTimer.singleShot(3200, self._out)

    def _out(self):
        self._a = QPropertyAnimation(self, b"windowOpacity")
        self._a.setDuration(450)
        self._a.setStartValue(1.0)
        self._a.setEndValue(0.0)
        self._a.setEasingCurve(QEasingCurve.Type.OutCubic)
        self._a.finished.connect(self.deleteLater)
        self._a.start()


class Page(QWidget):
    log  = pyqtSignal(str)
    done = pyqtSignal(bool)

    def __init__(self, t):
        super().__init__()
        self.t = t
        self._proc = None

    def _card(self):
        f = QFrame()
        f.setObjectName("card")
        return f

    def _run(self, apt_args, pbar=None, btn=None):
        if self._proc and self._proc.state() == QProcess.ProcessState.Running:
            return
        if btn:  btn.setEnabled(False)
        if pbar: pbar.setRange(0, 0)

        self._proc = QProcess()
        env = self._proc.processEnvironment()
        env.insert("DEBIAN_FRONTEND", "noninteractive")
        self._proc.setProcessEnvironment(env)

        self._proc.readyReadStandardOutput.connect(
            lambda: self.log.emit(
                self._proc.readAllStandardOutput().data().decode(errors="replace")
            )
        )
        self._proc.readyReadStandardError.connect(
            lambda: self.log.emit(
                self._proc.readAllStandardError().data().decode(errors="replace")
            )
        )

        def _fin(code, _):
            if pbar:
                pbar.setRange(0, 100)
                pbar.setValue(100 if code == 0 else 0)
            if btn:
                btn.setEnabled(True)
            self.done.emit(code == 0)

        self._proc.finished.connect(_fin)
        self._proc.start("pkexec", ["apt"] + apt_args)


class SearchPage(Page):
    def __init__(self, t):
        super().__init__(t)
        lay = QVBoxLayout(self)
        lay.setContentsMargins(28, 28, 28, 28)
        lay.setSpacing(16)

        c1 = self._card()
        l1 = QVBoxLayout(c1)
        l1.setContentsMargins(18, 18, 18, 18)
        l1.setSpacing(10)
        row = QHBoxLayout()
        row.setSpacing(10)
        self.inp = QLineEdit()
        self.inp.setPlaceholderText(t("search_placeholder"))
        self.inp.setMinimumHeight(40)
        self.btn = QPushButton(t("search_btn"))
        self.btn.setObjectName("primary")
        self.btn.setMinimumHeight(40)
        self.btn.setFixedWidth(110)
        row.addWidget(self.inp)
        row.addWidget(self.btn)
        self.pbar = QProgressBar()
        self.pbar.setFixedHeight(5)
        self.pbar.setVisible(False)
        l1.addLayout(row)
        l1.addWidget(self.pbar)
        lay.addWidget(c1)

        c2 = self._card()
        l2 = QVBoxLayout(c2)
        l2.setContentsMargins(18, 14, 18, 18)
        l2.setSpacing(8)
        self.res_lbl = QLabel(t("results_for"))
        self.res_lbl.setStyleSheet("color:#444444;font-size:11px;")
        self.lst = QListWidget()
        self.lst.setMinimumHeight(260)
        l2.addWidget(self.res_lbl)
        l2.addWidget(self.lst)
        lay.addWidget(c2)
        lay.addStretch()

        self.btn.clicked.connect(self._search)
        self.inp.returnPressed.connect(self._search)

    def _search(self):
        pkg = self.inp.text().strip()
        if not pkg:
            return
        self.lst.clear()
        self.pbar.setVisible(True)
        self.pbar.setRange(0, 0)
        self.btn.setEnabled(False)
        self.res_lbl.setText(f'{self.t("results_for")}  "{pkg}"')

        self._proc = QProcess()
        self._proc.readyReadStandardOutput.connect(
            lambda: [
                self.lst.addItem(ln.strip())
                for ln in self._proc.readAllStandardOutput()
                          .data().decode(errors="replace").splitlines()
                if ln.strip()
            ]
        )
        self._proc.readyReadStandardError.connect(
            lambda: self.log.emit(
                self._proc.readAllStandardError().data().decode(errors="replace")
            )
        )
        def _fin(code, _):
            self.pbar.setRange(0, 100)
            self.pbar.setValue(100)
            self.pbar.setVisible(False)
            self.btn.setEnabled(True)
            if self.lst.count() == 0:
                self.lst.addItem(self.t("no_results"))
            self.done.emit(code == 0)
        self._proc.finished.connect(_fin)
        self._proc.start("apt-cache", ["search", pkg])

    def retranslate(self):
        self.inp.setPlaceholderText(self.t("search_placeholder"))
        self.btn.setText(self.t("search_btn"))
        self.res_lbl.setText(self.t("results_for"))


