#!/usr/bin/env bash

APT="/usr/bin/apt"
TITLE="Pardus Package Manager"

# --- Locale Detection ---
LOCALE_STR="${LC_ALL:-${LC_MESSAGES:-${LANG:-en_US}}}"
case "$LOCALE_STR" in
    tr*|TR*) LANGUAGE="TR" ;;
    *)       LANGUAGE="EN" ;;
esac

if [ "$LANGUAGE" = "TR" ]; then
    MENU_TEXT="Yapmak istediğiniz işlemi seçin:"
    INSTALL="Seçtiğiniz paketi sisteminize kurar"
    REMOVE="Seçtiğiniz paketi sisteminizden kaldırır"
    UPDATE="Sistemi günceller"
    UPGRADE="Sistemi yükseltir"
    SEARCH="Seçtiğiniz paketi arar"
    EXIT="Çıkış yapar"
    PKG_TEXT="Paket adını girin:"
    ROOT_WARN1="Dikkat: Bu işlem için root olmanız gerekir"
    ROOT_WARN2="Lütfen root olarak çalıştırınız"
else
    MENU_TEXT="Select operation:"
    INSTALL="Install's your desired package"
    REMOVE="Remove's your desired package"
    UPDATE="Update's the system"
    UPGRADE="Upgrade's the system "
    SEARCH="Search's for your desired package"
    EXIT="Exits"
    PKG_TEXT="Enter package name:"
    ROOT_WARN1="Warning: For this operation, you must be root"
    ROOT_WARN2="Please be root"
fi

# --- Main Menu ---
CHOICE=$(whiptail --title "$TITLE" --menu "$MENU_TEXT" 20 70 6 \
"install" "$INSTALL" \
"remove" "$REMOVE" \
"update" "$UPDATE" \
"upgrade" "$UPGRADE" \
"search" "$SEARCH" \
"exit" "$EXIT" \
3>&1 1>&2 2>&3)

[ $? -ne 0 ] && exit 0
[ "$CHOICE" = "exit" ] && exit 0

# --- Update / Upgrade (no package needed) ---
if [ "$CHOICE" = "update" ] || [ "$CHOICE" = "upgrade" ]; then
    whiptail --title "$TITLE" --infobox "Processing..." 8 50
    sleep 1
    $APT "$CHOICE" -y
    exit 0
fi

# --- Ask for Package ---
PACKAGE=$(whiptail --inputbox "$PKG_TEXT" 10 60 3>&1 1>&2 2>&3)

[ $? -ne 0 ] &&
[ -z "$PACKAGE" ] &&

# --- Execute ---
whiptail --title "$TITLE" --infobox "Processing..." 8 50
sleep 1

case "$CHOICE" in
    install)
	if [ "$EUID" -ne 0 ]; then
            echo "$ROOT_WARN1"
            echo "$ROOT_WARN2"
            exit 1
	else
          $APT install -y "$PACKAGE"
		  sleep 2
	fi
        ;;
    remove)
        if [ "$EUID" -ne 0 ]; then
            echo "$ROOT_WARN1"
            echo "$ROOT_WARN2"
            exit 1
        else
            $APT remove --autoremove --purge -y "$PACKAGE"
			sleep 1
        fi
        ;;
    update)
        if [ "$EUID" -ne 0 ]; then
            echo "$ROOT_WARN1"
            echo "$ROOT_WARN2"
            exit 1
        else
            $APT update
			sleep 1
        fi
	;;
    upgrade)
        if [ "$EUID" -ne 0 ]; then
            echo "$ROOT_WARN1"
            echo "$ROOT_WARN2"
            exit 1
        else
	        $APT upgrade -y
		sleep 1
        fi
	;;
    search)
        $APT search "$PACKAGE"
        ;;
esac
